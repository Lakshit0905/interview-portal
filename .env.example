# Storage driver: "json" (default, file-based) or "prisma" (PostgreSQL)
DATA_DRIVER=json

# Required only if DATA_DRIVER=prisma
DATABASE_URL="postgresql://user:password@localhost:5432/interview_portal"

# AI features (optional). Without a key, AI modules use built-in offline heuristics.
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-20250514
